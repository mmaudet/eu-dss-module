{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "EU-DSS Sign",
  "version": "0.1.0",
  "identifier": "com.linagora.eudss",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "EU-DSS Sign",
        "width": 1180,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/eu-dss-server": "eu-dss-server"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "fr-FR"
      },
      "nsis": {
        "languages": ["French"],
        "displayLanguageSelector": false
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
